  hostname          = "your-machine-name";
  tailscaleHost     = "your-machine.your-tailnet.ts.net";
  username          = "your-unix-username";
  sshPublicKey      = "ssh-rsa AAAA... user@host";
  resticRepository  = "s3:https://nbg1.your-objectstorage.com/your-bucket-name";
}
